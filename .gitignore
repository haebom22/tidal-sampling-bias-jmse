# Data — large and reproducible from scripts + public APIs (KHOA, GEE, FES2022b, GLO30).
# Includes 24 GB FES2022b grids, raw KHOA/GEE pulls, and large DEM/extent outputs.
# The small derived tables under data/outputs/tables/ are regenerable too; release
# the curated subset via Zenodo (see manuscript "Data and code availability").
data/

# Reference papers (external / copyrighted)
reference/
# Full-text PDF/extract of external papers (copyrighted); notes/metadata stay tracked
manuscript/related_work/*.pdf
manuscript/related_work/*.txt

# Separate manuscripts in progress (own repos) — kept locally, not tracked here
manuscript2/
manuscript3/
scripts/generate_paper2_figures.py

# Runtime logs & scratch
logs/
.cache/

# Credentials
.aviso_credentials
.khoa_api_key
*.token

# IDE
.vscode/
.idea/

# Office temp / lock files (e.g. Word writes ~$draft_mdpi.docx while a doc is open)
~$*
*.tmp
.~lock.*#

# LaTeX build artifacts for the MDPI latex submission (source + PDF are tracked)
manuscript/latex_mdpi/*.aux
manuscript/latex_mdpi/*.log
manuscript/latex_mdpi/*.bbl
manuscript/latex_mdpi/*.blg
manuscript/latex_mdpi/*.out
manuscript/latex_mdpi/*.xdv
manuscript/*_latex_submission.zip

# Renamed submission-ready copies (derived from build outputs)
manuscript/submission/

# Author personal info and internal review reports — never publish
manuscript/저자정보/
manuscript/REVIEW_REPORT_paper1.md
manuscript/figures_maintext.zip

